# Enable LiteSpeed Cache
<IfModule LiteSpeed>
  CacheLookup on
  CacheEngine on
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
  # HTML - short cache with revalidation
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600, s-maxage=86400, must-revalidate"
  </FilesMatch>

  # CSS/JS with hashed filenames - long cache
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images/fonts - long cache
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Sitemap/robots - moderate cache
  <FilesMatch "(sitemap\.xml|robots\.txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Security headers
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"

  # Preload critical resources via Link header
  Header add Link "</fonts/inter-latin.woff2>; rel=preload; as=font; type=font/woff2; crossorigin"
  Header add Link "</fonts/poppins-latin.woff2>; rel=preload; as=font; type=font/woff2; crossorigin"
</IfModule>

# Brotli compression (LiteSpeed native)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# Gzip fallback
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml font/woff2
</IfModule>

# Disable ETags for static assets (Cache-Control is sufficient)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg|woff2|woff|ttf)$">
    Header unset ETag
  </FilesMatch>
</IfModule>
FileETag None

# SPA fallback - serve index.html for all routes
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
