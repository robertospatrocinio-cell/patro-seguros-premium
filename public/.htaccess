 # Hostinger / LiteSpeed friendly SPA routing
 <IfModule LiteSpeed>
   CacheLookup on
   CacheEngine on
 </IfModule>
 
 DirectoryIndex index.html
 Options -MultiViews +FollowSymLinks
 
 # Set MIME types
 <IfModule mod_mime.c>
   AddType application/xml .xml
   AddType text/plain .txt
   AddType image/svg+xml .svg
   AddCharset UTF-8 .xml .txt .html .js .css .json
 </IfModule>
 
 # ----------------------------------------------------------------------
 # | Compression and Pre-compressed Static Assets                       |
 # ----------------------------------------------------------------------
 
 <IfModule mod_rewrite.c>
   RewriteEngine On
   RewriteBase /
 
   # Serve Brotli-compressed files if they exist and the client supports Brotli.
   RewriteCond %{HTTP:Accept-Encoding} br
   RewriteCond %{REQUEST_FILENAME}.br -f
   RewriteRule ^(.*)$ $1.br [L]
   
   # Set correct content type and encoding for .br files
   <FilesMatch "\.js\.br$">
     Header set Content-Type "application/javascript"
     Header set Content-Encoding br
   </FilesMatch>
   <FilesMatch "\.css\.br$">
     Header set Content-Type "text/css"
     Header set Content-Encoding br
   </FilesMatch>
   <FilesMatch "\.html\.br$">
     Header set Content-Type "text/html"
     Header set Content-Encoding br
   </FilesMatch>
   <FilesMatch "\.svg\.br$">
     Header set Content-Type "image/svg+xml"
     Header set Content-Encoding br
   </FilesMatch>
   <FilesMatch "\.json\.br$">
     Header set Content-Type "application/json"
     Header set Content-Encoding br
   </FilesMatch>
 
   # Serve Gzip-compressed files if Brotli is not supported and .gz files exist.
   RewriteCond %{HTTP:Accept-Encoding} gzip
   RewriteCond %{REQUEST_FILENAME}.gz -f
   RewriteRule ^(.*)$ $1.gz [L]
   
   <FilesMatch "\.js\.gz$">
     Header set Content-Type "application/javascript"
     Header set Content-Encoding gzip
   </FilesMatch>
   <FilesMatch "\.css\.gz$">
     Header set Content-Type "text/css"
     Header set Content-Encoding gzip
   </FilesMatch>
   <FilesMatch "\.html\.gz$">
     Header set Content-Type "text/html"
     Header set Content-Encoding gzip
   </FilesMatch>
   <FilesMatch "\.svg\.gz$">
     Header set Content-Type "image/svg+xml"
     Header set Content-Encoding gzip
   </FilesMatch>
   <FilesMatch "\.json\.gz$">
     Header set Content-Type "application/json"
     Header set Content-Encoding gzip
   </FilesMatch>
 </IfModule>
 
 <IfModule mod_expires.c>
   ExpiresActive On
   ExpiresByType text/html "access plus 1 hour"
   ExpiresByType text/css "access plus 1 year"
   ExpiresByType application/javascript "access plus 1 year"
   ExpiresByType image/webp "access plus 1 year"
   ExpiresByType image/png "access plus 1 year"
   ExpiresByType image/jpeg "access plus 1 year"
   ExpiresByType image/svg+xml "access plus 1 year"
   ExpiresByType font/woff2 "access plus 1 year"
   ExpiresByType font/woff "access plus 1 year"
   ExpiresByType application/json "access plus 1 day"
   ExpiresByType application/manifest+json "access plus 1 week"
   ExpiresByType image/x-icon "access plus 1 year"
 </IfModule>
 
 <IfModule mod_headers.c>
   <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg|woff2|woff|ttf|avif)$">
     Header set Cache-Control "public, max-age=31536000, immutable"
     Header unset ETag
     Header set X-Content-Type-Options "nosniff"
   </FilesMatch>
 
   <FilesMatch "\.(html|xml|json|txt)$">
     Header set Cache-Control "public, max-age=600, stale-while-revalidate=3600"
     FileETag MTime Size
   </FilesMatch>
 
    <FilesMatch "^(sitemap[^/]*\.xml)$">
    <FilesMatch "^robots\.txt$">
      Header set Cache-Control "public, max-age=86400"
      Header set Content-Type "text/plain; charset=UTF-8"
    </FilesMatch>

     Header set Cache-Control "public, max-age=86400"
     Header set Content-Type "application/xml; charset=UTF-8"
   </FilesMatch>
 
   <FilesMatch "^sw\.js$">
     Header set Cache-Control "public, max-age=0, must-revalidate"
   </FilesMatch>
 
   Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
   Header always set X-Content-Type-Options "nosniff"
   Header always set X-Frame-Options "SAMEORIGIN"
   Header always set Referrer-Policy "strict-origin-when-cross-origin"
   Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
 </IfModule>
 
 <IfModule mod_brotli.c>
   AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/xml application/xml application/manifest+json text/plain
 </IfModule>
 
 <IfModule mod_deflate.c>
   AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml application/manifest+json text/plain font/woff2
 </IfModule>
 
 <IfModule mod_rewrite.c>
   # Force apex -> www (canonical host is www.patroseguros.com.br)
   RewriteCond %{HTTP_HOST} ^patroseguros\.com\.br$ [NC]
   RewriteRule ^ https://www.patroseguros.com.br%{REQUEST_URI} [R=301,L]
 
   # Force HTTPS
   RewriteCond %{HTTPS} !=on
   RewriteRule ^ https://www.patroseguros.com.br%{REQUEST_URI} [R=301,L]
 
  # ----------------------------------------------------------------------
  # | Legacy WordPress URL cleanup (consolidate authority on canonical)  |
  # ----------------------------------------------------------------------
  # Old WP slugs with "-2/" suffix → redirect to the current canonical URL.
  # Discovered via Semrush: Google still indexes these duplicates, diluting
  # ranking signals. 301 sends authority to the new pages.
  RewriteRule ^seguro-maquinas-e-equipamentos-2/?$ /seguro-maquinas-industriais [R=301,L]
  RewriteRule ^seguro-residencial-2/?$ /seguro-residencial [R=301,L]
  RewriteRule ^seguro-empresarial-2/?$ /seguro-empresarial [R=301,L]
  RewriteRule ^seguro-auto-2/?$ /seguro-auto [R=301,L]
  RewriteRule ^seguro-vida-2/?$ /seguro-vida [R=301,L]
  # Generic catch-all for any other legacy "-2/" slug → strip suffix
  RewriteRule ^([a-z0-9-]+)-2/?$ /$1 [R=301,L,NC]

  # Strip trailing slash on non-asset URLs (canonical form has no trailing /)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} ^/.+/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

   # Exclude existing files/special routes from SPA fallback
   RewriteRule ^(sitemap[^/]*\.xml|robots\.txt|sw\.js|favicon\.(ico|png)|manifest\.webmanifest)$ - [L,NC]
 
   # Any sitemap*.xml that does not exist on disk must 404 — never fall through
   # to the SPA index.html (which would make Google see HTML in place of XML).
   RewriteCond %{REQUEST_URI} ^/sitemap[^/]*\.xml$ [NC]
   RewriteCond %{REQUEST_FILENAME} !-f
   RewriteRule ^ - [R=404,L]
 
   # Existing files/directories
   RewriteCond %{REQUEST_FILENAME} -f [OR]
   RewriteCond %{REQUEST_FILENAME} -d
   RewriteRule ^ - [L]
 
   # SPA Fallback
   RewriteRule ^ index.html [L]
 </IfModule>
 
 ErrorDocument 404 /404.html
